{
  "name": "stock-management",
  "version": "1.0.5",
  "description": "Professional Electron stock management desktop app.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir",
    "generate-icon": "node scripts/generate-icon.js"
  },
  "keywords": [
    "electron",
    "stock",
    "inventory"
  ],
  "author": "Usama",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.usama.stockmanagement",
    "productName": "Stock Management",
    "directories": {
      "output": "dist"
    },
    "icon": "Icons/app.ico",
    "files": [
      "src/**/*",
      "Icons/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "Icons/app.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "installerIcon": "Icons/app.ico",
      "uninstallerIcon": "Icons/app.ico"
    }
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "icojs": "^1.0.0"
  }
}
