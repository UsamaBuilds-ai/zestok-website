{
  "name": "stock-management",
  "version": "1.2.5",
  "description": "Professional Electron stock management desktop app.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir",
    "test": "node --test",
    "migrate": "node src/db/migrate.js"
  },
  "keywords": [
    "electron",
    "stock",
    "inventory"
  ],
  "author": "Usama",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "build": {
    "appId": "com.usama.stockmanagement",
    "productName": "Stock Management",
    "directories": {
      "output": "dist"
    },
    "icon": "Icons/stock.ico",
    "files": [
      "src/**/*",
      "Icons/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/bcrypt/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "Icons/stock.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "Icons/stock.ico",
      "uninstallerIcon": "Icons/stock.ico",
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "guid": "com.usama.stockmanagement",
      "shortcutName": "Stock Management",
      "include": "build/installer.nsh",
      "runAfterFinish": true,
      "warningsAsErrors": false
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "icojs": "^1.0.0",
    "pg": "^8.22.0"
  },
  "allowScripts": {
    "electron@31.7.7": true
  }
}
